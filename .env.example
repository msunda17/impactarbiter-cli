# ImpactArbiter CLI Configuration
# Copy this file to .env and set your preferred values

# LLM Model (required for auto-heal command)
# Examples:
#   - OpenAI: gpt-4o, gpt-4-turbo
#   - Anthropic: anthropic/claude-3-5-sonnet-20241022
#   - Vertex AI: vertex_ai/gemini-2.5-pro, vertex_ai/gemini-2.5-flash
#   - Local: ollama/llama2
IMPACTARBITER_MODEL=vertex_ai/gemini-2.5-pro

# Database path (optional, defaults to nextpaper.db in current directory)
# IMPACTARBITER_DB=/path/to/custom/db.sqlite3

# Provider-specific API keys (if needed)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
